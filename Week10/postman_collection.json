{
  "info": {
    "name": "Flask API Testing - Fixed",
    "_postman_id": "fixed-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "item": [
    {
      "name": "Reset Data",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/reset"
      }
    },

    {
      "name": "1. Create User - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var data = pm.response.json();",
              "",
              "pm.test('Name correct', function () {",
              "    pm.expect(data.name).to.eql('An');",
              "});",
              "",
              "pm.test('Has id', function () {",
              "    pm.expect(data).to.have.property('id');",
              "});",
              "",
              "pm.environment.set('user_id', data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"name\": \"An\" }"
        },
        "url": "http://localhost:5000/users"
      }
    },

    {
      "name": "2. Create User - Empty Name",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "var data = pm.response.json();",
              "",
              "pm.test('Has error', function () {",
              "    pm.expect(data).to.have.property('error');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"name\": \"\" }"
        },
        "url": "http://localhost:5000/users"
      }
    },

    {
      "name": "3. Create User - Missing Name",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": "http://localhost:5000/users"
      }
    },

    {
      "name": "4. Get Users After Insert",
      "item": [
        {
          "name": "Create User A",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"name\": \"An\" }" },
            "url": "http://localhost:5000/users"
          }
        },
        {
          "name": "Create User B",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"name\": \"Binh\" }" },
            "url": "http://localhost:5000/users"
          }
        },
        {
          "name": "Get Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "",
                  "pm.test('Has 2 users', function () {",
                  "    pm.expect(data.length).to.eql(3);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/users"
          }
        }
      ]
    },

    {
      "name": "5. Create Task - Success",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "pm.environment.set('user_id', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"name\": \"An\" }" },
            "url": "http://localhost:5000/users"
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "",
                  "pm.test('Title correct', function () {",
                  "    pm.expect(data.title).to.eql('Task 1');",
                  "});",
                  "",
                  "pm.test('User id correct', function () {",
                  "    pm.expect(data.user_id).to.eql(parseInt(pm.environment.get('user_id')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"title\": \"Task 1\", \"user_id\": {{user_id}} }"
            },
            "url": "http://localhost:5000/tasks"
          }
        }
      ]
    },

    {
      "name": "6. Create Task - Invalid User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "var data = pm.response.json();",
              "",
              "pm.test('Has error', function () {",
              "    pm.expect(data).to.have.property('error');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"title\": \"Task 1\", \"user_id\": 999 }"
        },
        "url": "http://localhost:5000/tasks"
      }
    },

    {
      "name": "7. Get Tasks After Insert",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "pm.environment.set('user_id', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"name\": \"An\" }" },
            "url": "http://localhost:5000/users"
          }
        },
        {
          "name": "Create Task 1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"title\": \"Task 1\", \"user_id\": {{user_id}} }"
            },
            "url": "http://localhost:5000/tasks"
          }
        },
        {
          "name": "Create Task 2",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"title\": \"Task 2\", \"user_id\": {{user_id}} }"
            },
            "url": "http://localhost:5000/tasks"
          }
        },
        {
          "name": "Get Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "",
                  "pm.test('Has 2 tasks', function () {",
                  "    pm.expect(data.length).to.eql(3);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/tasks"
          }
        }
      ]
    }
  ]
}